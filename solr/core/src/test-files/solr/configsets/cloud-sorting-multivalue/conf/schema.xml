<!--
  Schema for testing sort on multi-valued fields in SolrCloud (SOLR-12457).
  Includes explicit TrieIntField and IntPointField types to allow testing
  both field implementations in the same cluster.
-->
<schema name="cloud-sorting-multivalue" version="1.7">

  <fieldType name="string" class="solr.StrField" sortMissingLast="true"/>
  <fieldType name="long" class="solr.LongPointField" docValues="true"/>

  <!--
    Deprecated trie-based multi-valued integer field.
    Uses SortedSetDocValues, so field(field,min|max) creates a STRING-based sort.
  -->
  <fieldType name="trie_int" class="solr.TrieIntField" docValues="true" precisionStep="0"
             positionIncrementGap="0"/>

  <!--
    Modern points-based multi-valued integer field.
    Uses SortedNumericDocValues, so field(field,min|max) creates an INT-based sort.
  -->
  <fieldType name="point_int" class="solr.IntPointField" docValues="true"/>

  <!-- id and versioning -->
  <field name="id" type="string" indexed="true" stored="true" multiValued="false" required="true"/>
  <field name="_version_" type="long" indexed="true" stored="true"/>

  <!--
    Multi-valued trie integer field with docValues.
    Reproduces the SOLR-12457 issue when used with field(trie_int_mv,max) sort
    in a distributed context (2+ shards).
  -->
  <dynamicField name="*_tis" type="trie_int" indexed="true" stored="true" multiValued="true"
                docValues="true"/>

  <!--
    Multi-valued point integer field with docValues.
    Used to verify whether the same issue exists for points-based fields.
  -->
  <dynamicField name="*_is_p" type="point_int" indexed="true" stored="true" multiValued="true"
                docValues="true"/>

  <uniqueKey>id</uniqueKey>

</schema>
